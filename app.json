{
  "expo": {
    "name": "muvment-driver",
    "slug": "muvment-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.muvmentdriver"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "package": "com.anonymous.muvmentdriver"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow Muvment Driver to use your camera to capture checklist photos."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Muvment Driver to use your location for trip navigation."
        }
      ],
      "expo-notifications",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "98609434-e28f-411e-9927-96417b3eb1c1"
      }
    }
  }
}
